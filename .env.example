# Copy this file to .env.local and fill in your values
# These must also be set in Netlify > Site Settings > Environment Variables

# Google Gemini API Key
# Local dev: use GEMINI_API_KEY
# Netlify: use VITE_GEMINI_API_KEY (so Vite exposes it to the browser bundle)
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Airtable Configuration
VITE_AIRTABLE_PAT=your_airtable_personal_access_token_here
VITE_AIRTABLE_BASE_ID=your_airtable_base_id_here
